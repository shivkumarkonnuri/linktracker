# OS-level CVEs with no fix available in Debian 13 (trixie) as of 2026-07-04
# These are in the python:3.12-slim base image and cannot be fixed by updating
# application dependencies. Acknowledged and tracked for future base image updates.

# curl/libcurl — SMB connection reuse + cookie leak
CVE-2026-5773
CVE-2026-6276

# gzip — LZH buffer overflow
CVE-2026-41992

# libacl1 — symlink traversal
CVE-2026-54369

# ncurses — buffer overflow
CVE-2025-69720

# perl-base — path traversal, heap overflow, DoS
CVE-2026-42496
CVE-2026-8376
CVE-2026-42497
CVE-2026-48962
CVE-2026-9538

# perl-base — regex trie 16-bit overflow, fixed upstream in Perl 5.43.10,
# not yet backported to Debian 13 (trixie) perl-base as of 2026-07-18
CVE-2026-13221

# util-linux family — integer overflow in libblkid partition parsing,
# no fix available in Debian 13 (trixie) as of 2026-07-18
CVE-2026-53615

# curl/libcurl — multiple issues (SSH host verification, TLS config,
# proxy auth state, mTLS reuse, use-after-free, SSL session disclosure),
# no fix available in Debian 13 (trixie) as of 2026-07-18
CVE-2026-12064
CVE-2026-8286
CVE-2026-8927
CVE-2026-8932
CVE-2026-9079
CVE-2026-9080
CVE-2026-9545

# perl-base — integer overflow in S_measure_struct (pack/unpack),
# no fix available in Debian 13 (trixie) as of 2026-07-18
CVE-2026-57432
